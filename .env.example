# Local provider: ollama | lmstudio | llamacpp | vllm
RELAY_LOCAL_PROVIDER=ollama
LOCAL_BASE_URL=http://localhost:11434
LOCAL_MODEL=llama3.1:8b
# Legacy aliases still work:
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1:8b

# Cloud policy: disabled by default
RELAY_ENABLE_CLOUD=0
RELAY_PRIVACY_MODE=balanced
RELAY_MIN_LOCAL_CONFIDENCE=0.62
RELAY_MAX_SUBTASKS=6

# Cloud provider: openrouter or openai-compatible
RELAY_CLOUD_PROVIDER=openrouter

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Relay

# Cloud model pool: capability -> model (OpenRouter only). JSON object merged over
# the built-in defaults. Subtasks route to the model mapped to their capability;
# anything unmapped uses OPENROUTER_MODEL above.
# RELAY_CLOUD_MODEL_MAP={"reasoning":"anthropic/claude-opus-4.8","current_info":"openai/gpt-5.5"}

# Generic OpenAI-compatible fallback
OPENAI_COMPAT_BASE_URL=https://api.openai.com/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-5.5

# Legacy MODELROUTER_* variables are still accepted as fallbacks.